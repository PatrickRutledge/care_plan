{
  "resourceType": "Bundle",
  "id": "careplan-followup-bundle",
  "type": "transaction",
  "_comment": "FHIR R4 mirror of careplan-followup-example.xml (WF3: monitor -> evaluate -> revise). Assumes the base resources from careplan-example.fhir.json (Patient, Practitioners, Org) already exist. The evaluation loop maps to Goal.achievementStatus + Goal.outcomeReference; the re-directed service maps to a new Task whose reasonReference is the triggering Observation.",
  "entry": [
    {
      "fullUrl": "urn:uuid:enc-e1",
      "request": { "method": "PUT", "url": "Encounter/E1" },
      "resource": {
        "resourceType": "Encounter",
        "id": "E1",
        "_comment": "Phase 6 Monitor: CDA encounter moodCode=EVN -> FHIR Encounter status=finished.",
        "status": "finished",
        "class": { "system": "http://terminology.hl7.org/CodeSystem/v3-ActCode", "code": "AMB", "display": "ambulatory" },
        "type": [ { "coding": [ { "system": "http://snomed.info/sct", "code": "390906007", "display": "Follow-up encounter" } ] } ],
        "subject": { "reference": "Patient/PT-12345" },
        "period": { "start": "2026-09-10" }
      }
    },
    {
      "fullUrl": "urn:uuid:obs-a1c",
      "request": { "method": "PUT", "url": "Observation/A1C-1" },
      "resource": {
        "resourceType": "Observation",
        "id": "A1C-1",
        "_comment": "Phase 7 Evaluate: the measured outcome. CDA observation moodCode=EVN + value -> FHIR Observation status=final + valueQuantity. interpretation H = above goal.",
        "status": "final",
        "category": [ { "coding": [ { "system": "http://terminology.hl7.org/CodeSystem/observation-category", "code": "laboratory" } ] } ],
        "code": { "coding": [ { "system": "http://loinc.org", "code": "4548-4", "display": "Hemoglobin A1c" } ] },
        "subject": { "reference": "Patient/PT-12345" },
        "encounter": { "reference": "Encounter/E1" },
        "effectiveDateTime": "2026-09-09",
        "valueQuantity": { "value": 7.8, "unit": "%", "system": "http://unitsofmeasure.org", "code": "%" },
        "interpretation": [ { "coding": [ { "system": "http://terminology.hl7.org/CodeSystem/v3-ObservationInterpretation", "code": "H", "display": "High" } ] } ]
      }
    },
    {
      "fullUrl": "urn:uuid:goal-g1",
      "request": { "method": "PUT", "url": "Goal/G1" },
      "resource": {
        "resourceType": "Goal",
        "id": "G1",
        "_comment": "Goal re-evaluated. CDA: goal stays statusCode=active. FHIR adds achievementStatus=not-achieved and outcomeReference -> the measuring Observation. THIS is the FHIR encoding of 'evaluate the goal'.",
        "lifecycleStatus": "active",
        "achievementStatus": {
          "coding": [ { "system": "http://terminology.hl7.org/CodeSystem/goal-achievement", "code": "not-achieved", "display": "Not Achieved" } ]
        },
        "description": { "text": "Lower A1c to below 7.0% within 6 months" },
        "subject": { "reference": "Patient/PT-12345" },
        "target": [
          {
            "measure": { "coding": [ { "system": "http://loinc.org", "code": "4548-4", "display": "Hemoglobin A1c" } ] },
            "detailQuantity": { "value": 7.0, "unit": "%", "comparator": "<" },
            "dueDate": "2026-12-08"
          }
        ],
        "outcomeReference": [ { "reference": "Observation/A1C-1", "display": "A1c 7.8% (2026-09-09)" } ]
      }
    },
    {
      "fullUrl": "urn:uuid:task-t3",
      "request": { "method": "PUT", "url": "Task/T3" },
      "resource": {
        "resourceType": "Task",
        "id": "T3",
        "_comment": "Phase 8 Revise: a NEW directed service. CDA act moodCode=RQO with REFR->goal and RSON->outcome. In FHIR: basedOn the CarePlan (which carries goal G1) and reasonReference the triggering Observation. NOTE: R4 Task has no direct 'serves goal' link as strong as CDA's REFR; goal linkage rides through CarePlan.goal + CarePlan.activity. Captured in cda-to-fhir-mapping.md.",
        "identifier": [ { "system": "urn:oid:2.16.840.1.113883.19.5.99999.20", "value": "T3" } ],
        "basedOn": [ { "reference": "CarePlan/CarePlan-0001" } ],
        "status": "requested",
        "intent": "order",
        "priority": "routine",
        "code": { "coding": [ { "system": "http://snomed.info/sct", "code": "386359008", "display": "Medication management" } ], "text": "Initiate/adjust pharmacologic therapy for glycemic control" },
        "for": { "reference": "Patient/PT-12345" },
        "owner": { "reference": "Practitioner/DR-1" },
        "requester": { "reference": "Practitioner/DR-1" },
        "reasonReference": { "reference": "Observation/A1C-1", "display": "A1c above goal (7.8%)" },
        "encounter": { "reference": "Encounter/E1" },
        "restriction": { "period": { "start": "2026-09-10", "end": "2026-10-10" } }
      }
    },
    {
      "fullUrl": "urn:uuid:careplan",
      "request": { "method": "PUT", "url": "CarePlan/CarePlan-0001" },
      "resource": {
        "resourceType": "CarePlan",
        "id": "CarePlan-0001",
        "_comment": "The hub, now updated: same goal G1, activities reference both the completed task T1 and the new task T3. CarePlan is where FHIR ties goals and services together.",
        "identifier": [ { "system": "urn:oid:2.16.840.1.113883.19.5.99999.1", "value": "CarePlan-0001" } ],
        "status": "active",
        "intent": "plan",
        "title": "Care Plan - Jane Q. Patient",
        "subject": { "reference": "Patient/PT-12345" },
        "goal": [ { "reference": "Goal/G1" } ],
        "activity": [
          { "reference": { "reference": "Task/T1", "display": "Diabetes education (completed)" } },
          { "reference": { "reference": "Task/T3", "display": "Pharmacologic therapy management (requested)" } }
        ]
      }
    }
  ]
}
